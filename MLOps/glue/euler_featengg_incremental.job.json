{
  "jobConfig": {
    "name": "euler-featengg-incremental",
    "description": "Euler feature engineering (Turno methodology) -> euler_featengg feature store. Incremental read by --process_date (defaults to yesterday), Iceberg MERGE, all-vehicles. Calls src/euler_features.py via applyInPandas.",
    "role": "arn:aws:iam::894429711714:role/AWSGlueServiceRole-TurnoML",
    "command": "glueetl",
    "version": "5.1",
    "runtime": null,
    "workerType": "G.1X",
    "numberOfWorkers": 2,
    "maxCapacity": 2,
    "jobRunQueuingEnabled": true,
    "maxRetries": 1,
    "timeout": 480,
    "maxConcurrentRuns": 1,
    "security": "none",
    "scriptName": "euler_featengg_incremental.py",
    "scriptLocation": "s3://aws-glue-assets-894429711714-ap-south-1/scripts/",
    "language": "python-3",
    "spark": true,
    "sparkConfiguration": "standard",
    "jobParameters": [
      {"key": "--datalake-formats", "value": "iceberg", "existing": false},
      {"key": "--additional-python-modules", "value": "scikit-learn", "existing": false},
      {"key": "--extra-py-files", "value": "s3://aws-glue-assets-894429711714-ap-south-1/scripts/euler_features.py", "existing": false},
      {"key": "--raw_bucket", "value": "oem-iot-data", "existing": false},
      {"key": "--warehouse", "value": "s3://rcs-mlops-data/iceberg/", "existing": false},
      {"key": "--enable-continuous-cloudwatch-log", "value": "true", "existing": false},
      {"key": "--enable-metrics", "value": "true", "existing": false},
      {"key": "--enable-observability-metrics", "value": "true", "existing": false},
      {"key": "--enable-spark-ui", "value": "true", "existing": false},
      {"key": "--spark-event-logs-path", "value": "s3://aws-glue-assets-894429711714-ap-south-1/sparkHistoryLogs/", "existing": false},
      {"key": "--conf", "value": "spark.sql.extensions=org.apache.iceberg.spark.extensions.IcebergSparkSessionExtensions --conf spark.sql.catalog.glue_catalog=org.apache.iceberg.spark.SparkCatalog --conf spark.sql.catalog.glue_catalog.catalog-impl=org.apache.iceberg.aws.glue.GlueCatalog --conf spark.sql.catalog.glue_catalog.warehouse=s3://rcs-mlops-data/iceberg/ --conf spark.sql.catalog.glue_catalog.io-impl=org.apache.iceberg.aws.s3.S3FileIO --conf spark.sql.catalog.glue_catalog.glue.skip-name-validation=true", "existing": false}
    ],
    "tags": [],
    "jobMode": "DEVELOPER_MODE",
    "developerMode": false,
    "connectionsList": [],
    "temporaryDirectory": "s3://aws-glue-assets-894429711714-ap-south-1/temporary/",
    "logging": true,
    "glueHiveMetastore": true,
    "etlAutoTuning": true,
    "metrics": true,
    "observabilityMetrics": true,
    "bookmark": "job-bookmark-disable",
    "sparkPath": "s3://aws-glue-assets-894429711714-ap-south-1/sparkHistoryLogs/",
    "flexExecution": true,
    "minFlexWorkers": null,
    "maintenanceWindow": null
  },
  "hasBeenSaved": false,
  "usageProfileName": null,
  "_deploy_notes": [
    "process_date is intentionally NOT a static jobParameter: the script defaults it to yesterday (UTC), so the daily scheduled trigger needs no dynamic argument. Backfill/reprocessing passes --process_date via StartJobRun --arguments.",
    "Unlike the third party's job.json this does NOT embed the script inline; upload euler_featengg_incremental.py to scriptLocation and euler_features.py to --extra-py-files (keep them versioned in git, not pasted into JSON).",
    "flexExecution=true uses Glue spare-capacity pricing (non-SLA daily batch). maxConcurrentRuns=1 avoids concurrent Iceberg MERGE conflicts; maxRetries=1 is safe because the MERGE is idempotent.",
    "Bump workerType to G.2X (or numberOfWorkers up) if a busy vehicle's full-history applyInPandas group OOMs.",
    "Verify raw_bucket for this account (oem-iot-data vs oem-data-iot)."
  ]
}
